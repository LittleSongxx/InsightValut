# ===================== InsightVault 配置示例 =====================
# 复制此文件为 .env，按下方说明填入你的密钥即可。
# 带 __FILL_ME__ 的字段必须填写，其余可保留默认值。

# ============================================================
# 一、必须填写的密钥
# ============================================================

# --- MinerU（PDF 解析服务）---
# 申请地址：https://mineru.net （免费注册，送额度）
# 不填写则无法导入 PDF 文件，MD/TXT 文件导入不受影响
MINERU_API_TOKEN=__FILL_ME_MINERU_TOKEN__
MINERU_BASE_URL=https://mineru.net/api/v4

# --- DashScope（阿里云百炼，大模型 + Embedding + 重排）---
# 申请地址：https://dashscope.console.aliyun.com （免费额度）
# 必须填写，查询问答、商品名称识别、图片摘要全部依赖此 API
OPENAI_API_KEY=__FILL_ME_DASHSCOPE_API_KEY__
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# 二、可选配置（一般保留默认即可）
# ============================================================

# --------- MinerU --------
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=0
MODELSCOPE_CACHE=./.cache/modelscope
HF_HOME=./.cache/huggingface
MD_ROOT_DIR=./temp-files/

# --------- 大模型 --------
DEEPSEEK_API_KEY=__FILL_ME_DEEPSEEK_API_KEY__
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-122b-a10b
LLM_AVAILABLE_MODELS=deepseek-v4-flash,qwen3.5-122b-a10b
LLM_DEFAULT_MODEL=deepseek-v4-flash
LLM_FALLBACK_MODEL=qwen3.5-122b-a10b
VL_MODEL=qwen3-vl-flash
LLM_DEFAULT_TEMPERATURE=0.1

# --------- Embedding（本地 BGE-M3 模型，首次导入时自动下载）--------
BGE_M3_PATH=./.cache/models/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cuda:0
BGE_FP16=1
ITEM_NAME_DIAG=1
EMBEDDING_DIM=1024

# --------- 重排（默认使用 DashScope API，无需下载本地模型）--------
# dashscope：调用百炼 Rerank API（优先）
# local    ：强制使用本地 FlagReranker 模型
RERANKER_MODE=dashscope
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
# 如需显式覆盖官方文本排序接口，可改这里
DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# 1 表示 DashScope/本地 Cross-Encoder 均不可用时直接报错，不再静默退化到关键词重叠
RERANKER_STRICT=0
BGE_RERANKER_LARGE=BAAI/bge-reranker-v2-m3
BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_FP16=1

# --------- Milvus --------
MILVUS_URL=http://127.0.0.1:19531
CHUNKS_COLLECTION=kb_chunks
ITEM_NAME_COLLECTION=kb_item_names
ENTITY_NAME_COLLECTION=kb_entities

# --------- 宿主机端口映射（Docker 启动默认值）--------
IMPORT_PORT=18000
QUERY_PORT=8001
FRONTEND_PORT=3002
REDIS_PORT=16380

# --------- Neo4j --------
NEO4J_URI=bolt://127.0.0.1:7688
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=insightvault123

# --------- MongoDB --------
MONGO_URL=mongodb://127.0.0.1:27018
MONGO_DB_NAME=insightvault_rag

# --------- 查询缓存（默认启用，推荐配合 Redis）--------
QUERY_CACHE_ENABLED=true
QUERY_CACHE_REDIS_URL=redis://127.0.0.1:16380/0
QUERY_CACHE_L1_MAX_ENTRIES=512
QUERY_CACHE_EMBEDDING_TTL_SEC=86400
QUERY_CACHE_RETRIEVAL_TTL_SEC=21600
QUERY_CACHE_GRAPH_TTL_SEC=21600
QUERY_CACHE_HYDE_TTL_SEC=86400
QUERY_CACHE_WEB_TTL_SEC=1800
QUERY_CACHE_RERANK_TTL_SEC=21600
QUERY_CACHE_ANSWER_TTL_SEC=3600

# --------- MinIO --------
MINIO_ENDPOINT=127.0.0.1:19100
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_PDF_DIR=pdf_files
MINIO_IMG_DIR=upload-images
MINIO_SECURE=False

# --------- 联网搜索（可选，不填本地知识库检索仍正常）--------
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse

# --------- 日志 --------
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days

# --------- 检索调参（推荐初始值）--------
HYBRID_DENSE_WEIGHT=0.75
HYBRID_SPARSE_WEIGHT=0.25
ITEM_NAME_DENSE_WEIGHT=0.85
ITEM_NAME_SPARSE_WEIGHT=0.15
BM25_ENABLED=false
BM25_TOP_K=8
BM25_CANDIDATE_LIMIT=800
BM25_K1=1.5
BM25_B=0.75
RRF_WEIGHT_EMBEDDING=1.0
RRF_WEIGHT_HYDE=0.9
RRF_WEIGHT_BM25=0.7
RRF_WEIGHT_KG=0.8
RERANK_SIMPLE_MAX_TOPK=3
RERANK_COMPLEX_MAX_TOPK=6
RERANK_KEEP_MIN_RATIO=0.35
RETRIEVAL_GRADER_CONFIDENT_SCORE=0.65
RETRIEVAL_GRADER_CONFIDENT_MARGIN=0.08
JUDGE_MAX_DOCS=3
JUDGE_MAX_TOTAL_CHARS=2400
